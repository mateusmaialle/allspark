# ============================================================
# Variáveis de ambiente — copie este arquivo para .env.local
# para rodar localmente. No Vercel, configure pelo painel.
# NUNCA commite o arquivo .env.local no Git.
# ============================================================

# Senha global de acesso ao catálogo
# Troque para uma senha forte de sua escolha
SITE_PASSWORD=sua-senha-aqui

# ID da planilha do Google Sheets
# Encontrado na URL da planilha:
# https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
SHEET_ID=seu-sheet-id-aqui

# Chave da API do Google Cloud (permissão: Google Sheets API, somente leitura)
# Obter em: https://console.cloud.google.com/
GOOGLE_API_KEY=sua-api-key-aqui

# Nome da aba da planilha onde os dados estão (padrão: Sheet1)
SHEET_NAME=Sheet1
